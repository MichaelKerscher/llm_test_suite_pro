# =========================
# llm_test_suite_pro
# .env.example
# =========================
# Hinweise:
# - Diese Datei NICHT mit Secrets befüllen und NICHT als .env committen.
# - Kopieren:  copy .env.example .env   (Windows)  |  cp .env.example .env (macOS/Linux)
# - Default-Pipeline: Loader -> LLM -> Judge -> Logging -> Aggregation

# -------------------------
# Run / Logging
# -------------------------
RUN_NAME=local-dev
RUNS_DIR=runs
LOG_LEVEL=INFO

# -------------------------
# Default LLM Provider
# -------------------------
# Provider-Auswahl:
# - provider_506     (externer Dienstleister / CompanyGPT Proxy, Beispiel 506.ai)
# - azure_openai     (Azure OpenAI, später)
# - openai_compat    (self-hosted oder OpenAI-kompatible Proxies, optional)
LLM_PROVIDER=provider_506

# Allgemeine Provider-Keys (werden von allen Providern genutzt, sofern relevant)
LLM_MODEL=gemini-2.5-flash
LLM_BASE_URL=https://api.506.ai
LLM_API_KEY=REPLACE_ME
LLM_TIMEOUT_S=60
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=

# Optional: Provider-spezifische Zusatzdaten
# - Extra HTTP Headers als JSON (String)
LLM_EXTRA_HEADERS_JSON={}
# - Extra Body Felder als JSON (String), wird in den Request-Body gemerged
LLM_EXTRA_BODY_JSON={}

# Optional: wenn Provider einen expliziten Endpoint-Pfad braucht (sonst hardcoded im Provider)
# Beispiele: /v1/chat/completions, /api/chat, /chat
LLM_ENDPOINT_PATH=

# -------------------------
# Judge (optional)
# -------------------------
JUDGE_ENABLE=true

# Standard: gleicher Provider wie LLM, kann aber getrennt werden
JUDGE_PROVIDER=provider_506
JUDGE_MODEL=gpt-4.1
JUDGE_BASE_URL=https://api.506.ai
JUDGE_API_KEY=REPLACE_ME
JUDGE_TIMEOUT_S=60
JUDGE_TEMPERATURE=0
JUDGE_MAX_TOKENS=

JUDGE_EXTRA_HEADERS_JSON={}
JUDGE_EXTRA_BODY_JSON={}
JUDGE_ENDPOINT_PATH=

# -------------------------
# Azure OpenAI (Vorbereitung)
# -------------------------
# Nur relevant, wenn LLM_PROVIDER=azure_openai oder JUDGE_PROVIDER=azure_openai
AZURE_OPENAI_ENDPOINT=https://<resource-name>.openai.azure.com
AZURE_OPENAI_API_KEY=REPLACE_ME
AZURE_OPENAI_API_VERSION=2024-xx-xx
# Azure nutzt meist "Deployment Name" statt direktem Modellnamen:
AZURE_OPENAI_DEPLOYMENT=<deployment-name>

# Optional: separate Azure Settings für Judge (falls Judge über anderes Deployment laufen soll)
AZURE_OPENAI_JUDGE_DEPLOYMENT=

# -------------------------
# Self-hosted / OpenAI-kompatibel (optional)
# -------------------------
# Nur relevant, wenn *_PROVIDER=openai_compat
OPENAI_COMPAT_BASE_URL=http://localhost:8000/v1
OPENAI_COMPAT_API_KEY=REPLACE_ME

# -------------------------
# Strategy Hook (CLI schaltet es an/aus)
# -------------------------
# Default Strategy, wenn Hook aktiv ist und kein --strategy gesetzt wurde:
DEFAULT_STRATEGY=S0

# Optional: Pfad zu Plugin-Hook (später nutzbar)
# Beispiel: plugins.my_hook:MyHook
STRATEGY_HOOK_PLUGIN=